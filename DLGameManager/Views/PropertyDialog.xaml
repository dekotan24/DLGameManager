<Window x:Class="DLGameManager.Views.PropertyDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="プロパティ" Width="560" Height="580" WindowStartupLocation="CenterOwner" Background="#1e1e2e" ResizeMode="CanResizeWithGrip" xmlns:views="clr-namespace:DLGameManager.Views;assembly=DLGameManager">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="Label" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#9399b2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,8,0,3" />
      </Style>
      <Style x:Key="Field" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#383850" />
        <Setter Property="Foreground" Value="#cdd6f4" />
        <Setter Property="TextBoxBase.CaretBrush" Value="#cdd6f4" />
        <Setter Property="BorderBrush" Value="#45455a" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="13" />
      </Style>
      <Style x:Key="ReadonlyField" TargetType="{x:Type TextBox}" BasedOn="{StaticResource Field}">
        <Setter Property="TextBoxBase.IsReadOnly" Value="True" />
        <Setter Property="Foreground" Value="#7a7a95" />
      </Style>
      <Style x:Key="Btn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#45455a" />
        <Setter Property="Foreground" Value="#cdd6f4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Margin" Value="4,0,0,0" />
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Style="{StaticResource Label}" Text="作品ID" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox Name="TbProductId" Style="{StaticResource Field}" />
          <ComboBox Name="CbSource" Grid.Column="1" Width="100" Margin="4,0,0,0" FontSize="13">
            <ComboBoxItem Content="DLsite" />
            <ComboBoxItem Content="FANZA" />
            <ComboBoxItem Content="" />
          </ComboBox>
        </Grid>
        <TextBlock Style="{StaticResource Label}" Text="タイトル" />
        <TextBox Name="TbTitle" Style="{StaticResource Field}" />
        <TextBlock Style="{StaticResource Label}" Text="サークル名" />
        <TextBox Name="TbCircle" Style="{StaticResource Field}" />
        <TextBlock Style="{StaticResource Label}" Text="タグ（カンマ区切り）" />
        <TextBox Name="TbTags" Style="{StaticResource Field}" TextWrapping="Wrap" AcceptsReturn="False" Height="50" />
        <TextBlock Style="{StaticResource Label}" Text="評価" />
        <ComboBox Name="CbRating" Width="100" HorizontalAlignment="Left" FontSize="13">
          <ComboBoxItem Content="未評価" />
          <ComboBoxItem Content="★" />
          <ComboBoxItem Content="★★" />
          <ComboBoxItem Content="★★★" />
          <ComboBoxItem Content="★★★★" />
          <ComboBoxItem Content="★★★★★" />
        </ComboBox>
        <TextBlock Style="{StaticResource Label}" Text="メモ" />
        <TextBox Name="TbMemo" Style="{StaticResource Field}" TextWrapping="Wrap" AcceptsReturn="True" Height="60" />
        <TextBlock Style="{StaticResource Label}" Text="フォルダパス" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox Name="TbFolderPath" Style="{StaticResource ReadonlyField}" />
          <Button Grid.Column="1" Content="変更" Style="{StaticResource Btn}" Click="OnChangeFolderPath" />
        </Grid>
        <TextBlock Style="{StaticResource Label}" Text="実行ファイル" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox Name="TbExePath" Style="{StaticResource ReadonlyField}" />
          <Button Grid.Column="1" Content="候補" Style="{StaticResource Btn}" Click="OnSelectExe" />
          <Button Grid.Column="2" Content="参照" Style="{StaticResource Btn}" Click="OnBrowseExe" />
        </Grid>
        <TextBlock Style="{StaticResource Label}" Text="サムネイルURL" />
        <TextBox Name="TbThumbUrl" Style="{StaticResource Field}" />
        <TextBlock Style="{StaticResource Label}" Text="情報" />
        <TextBlock Name="TbInfo" Foreground="#7a7a95" FontSize="11" TextWrapping="Wrap" />
        <CheckBox Name="CbRenameFolder" IsChecked="True" Margin="0,12,0,0" Foreground="#cdd6f4" FontSize="12" Content="保存時にフォルダ名を規則に合わせてリネームする" />
        <TextBlock Name="TbRenamePreview" Foreground="#7a7a95" FontSize="11" TextWrapping="Wrap" Margin="20,2,0,0" />
      </StackPanel>
    </ScrollViewer>
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="メタデータを再取得" Style="{StaticResource Btn}" Padding="12,6" Margin="0,0,8,0" Click="OnRefetch" />
      <Button Content="保存" Padding="16,6" Margin="0,0,4,0" Background="#89b4fa" Foreground="#1e1e2e" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="OnSave" />
      <Button Content="キャンセル" Style="{StaticResource Btn}" Padding="12,6" Click="OnCancel" />
    </StackPanel>
  </Grid>
</Window>