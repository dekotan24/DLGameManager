<Window x:Class="DLGameManager.Views.WatchFoldersDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="監視フォルダの設定" Width="600" Height="400" WindowStartupLocation="CenterOwner" Background="#1e1e2e" ResizeMode="CanResizeWithGrip" xmlns:views="clr-namespace:DLGameManager.Views;assembly=DLGameManager">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Foreground="#cdd6f4" FontSize="13" Margin="0,0,0,8" Text="監視するフォルダを追加すると、新しいサブフォルダが作成された時に自動で作品を登録します。" />
    <ListBox Name="FolderListBox" Grid.Row="1" Background="#2a2a3d" Foreground="#cdd6f4" BorderBrush="#45455a" FontSize="13">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Padding="4,2" Text="{Binding}" />
            <Button Grid.Column="1" Content="✕" Background="#00FFFFFF" Foreground="#f38ba8" BorderThickness="0" Cursor="Hand" Padding="8,2" FontSize="14" FontWeight="Bold" Tag="{Binding}" Click="OnRemoveFolder" />
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ListBox>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
      <Button Content="＋ フォルダを追加" Padding="12,6" Background="#89b4fa" Foreground="#1e1e2e" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="OnAddFolder" />
      <Button Content="既存フォルダを一括スキャン" Padding="12,6" Background="#45455a" Foreground="#cdd6f4" BorderThickness="0" Cursor="Hand" Click="OnScanExisting" />
    </StackPanel>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="閉じる" Padding="16,6" Background="#45455a" Foreground="#cdd6f4" BorderThickness="0" Cursor="Hand" Click="OnClose" />
    </StackPanel>
  </Grid>
</Window>