<Window x:Class="DLGameManager.Views.SelectExeDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="実行ファイルを選択" Width="600" Height="400" WindowStartupLocation="CenterOwner" Background="#1e1e2e" ResizeMode="CanResizeWithGrip" xmlns:views="clr-namespace:DLGameManager.Views;assembly=DLGameManager">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Text="起動する実行ファイルを選択してください" Foreground="#cdd6f4" FontSize="14" Margin="0,0,0,12" />
    <ListBox Name="ExeListBox" Grid.Row="1" Background="#2a2a3d" Foreground="#cdd6f4" BorderBrush="#45455a" FontSize="13" MouseDoubleClick="OnListBox_DoubleClick">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <TextBlock Padding="4,2" Text="{Binding}" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ListBox>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="カスタムパスを指定..." Padding="16,8" Margin="0,0,8,0" Background="#45455a" Foreground="#cdd6f4" BorderThickness="0" Cursor="Hand" Click="OnBrowse_Click" />
      <Button Content="選択" Padding="16,8" Margin="0,0,8,0" Background="#89b4fa" Foreground="#1e1e2e" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="OnSelect_Click" />
      <Button Content="キャンセル" Padding="16,8" Background="#45455a" Foreground="#cdd6f4" BorderThickness="0" Cursor="Hand" Click="OnCancel_Click" />
    </StackPanel>
  </Grid>
</Window>