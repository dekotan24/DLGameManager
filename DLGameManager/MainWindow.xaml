<Window x:Class="DLGameManager.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:DLGameManager.ViewModels" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" Title="DL Game Manager" Width="1240" Height="820" Icon="pack://application:,,,/icon.ico" WindowStartupLocation="CenterScreen" Background="#1e1e2e" AllowDrop="True" xmlns:dlgamemanager="clr-namespace:DLGameManager" Drop="OnDrop" DragOver="OnDragOver">
  <FrameworkElement.DataContext>
    <vm:MainViewModel />
  </FrameworkElement.DataContext>
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="BgSecondary" Color="#2a2a3d" />
      <SolidColorBrush x:Key="BgCard" Color="#313145" />
      <SolidColorBrush x:Key="BgCardHover" Color="#3b3b55" />
      <SolidColorBrush x:Key="FgPrimary" Color="#cdd6f4" />
      <SolidColorBrush x:Key="FgSecondary" Color="#9399b2" />
      <SolidColorBrush x:Key="AccentBlue" Color="#89b4fa" />
      <Style x:Key="DarkTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#383850" />
        <Setter Property="Foreground" Value="#cdd6f4" />
        <Setter Property="BorderBrush" Value="#45455a" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="TextBoxBase.CaretBrush" Value="#cdd6f4" />
        <Setter Property="FontSize" Value="14" />
      </Style>
      <Style x:Key="DarkButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#45455a" />
        <Setter Property="Foreground" Value="#cdd6f4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Background="{TemplateBinding Control.Background}" CornerRadius="4" Padding="{TemplateBinding Control.Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#55556a" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Background" Value="#65657a" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="AccentButton" TargetType="{x:Type Button}" BasedOn="{StaticResource DarkButton}">
        <Setter Property="Background" Value="#89b4fa" />
        <Setter Property="Foreground" Value="#1e1e2e" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Background="{TemplateBinding Control.Background}" CornerRadius="4" Padding="{TemplateBinding Control.Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#a0c4ff" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="#1a1a2e" Padding="8,4">
      <StackPanel Orientation="Horizontal">
        <Button Name="LibraryTabButton" Content="📚 ライブラリ" Style="{StaticResource DarkButton}" Padding="12,6" FontSize="13" Click="OnLibraryTab_Click" />
        <Button Name="BrowserTabButton" Content="🌐 ブラウザ" Style="{StaticResource DarkButton}" Padding="12,6" FontSize="13" Margin="4,0,0,0" Click="OnBrowserTab_Click" />
      </StackPanel>
    </Border>
    <Grid Row="1">
      <Grid Name="LibraryPanel" Visibility="{Binding IsLibraryTabActive, Converter={StaticResource BoolToVisibility}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}" Padding="12,12,12,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" Margin="0,0,8,0" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}">
              <Control.Template>
                <ControlTemplate TargetType="{x:Type TextBox}">
                  <Border Background="#383850" BorderBrush="#45455a" BorderThickness="1" CornerRadius="4">
                    <Grid>
                      <ScrollViewer Name="PART_ContentHost" Margin="8,6" />
                      <TextBlock Text="タイトル / サークル / タグで検索..." Foreground="#666680" Margin="10,8" IsHitTestVisible="False" Visibility="{Binding Text.IsEmpty, Converter={StaticResource BoolToVisibility}, RelativeSource={RelativeSource TemplatedParent}}" />
                    </Grid>
                  </Border>
                </ControlTemplate>
              </Control.Template>
            </TextBox>
            <ComboBox Grid.Column="1" Width="220" Margin="0,0,8,0" FontSize="13" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" />
            <Button Grid.Column="2" Style="{StaticResource AccentButton}" Content="＋ 作品追加" Margin="0,0,4,0" Click="OnAddGame_Click" />
            <Button Grid.Column="3" Style="{StaticResource DarkButton}" Content="📁 一括追加" Margin="0,0,4,0" Click="OnBatchAdd_Click" />
            <Button Grid.Column="4" Style="{StaticResource DarkButton}" Content="👁 監視設定" Click="OnWatchFolders_Click" />
          </Grid>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource BgSecondary}" Padding="12,0,12,8">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="フィルタ:" Foreground="#9399b2" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Width="100" FontSize="12" Margin="0,0,6,0" ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding SelectedSource}" />
            <ComboBox Width="130" FontSize="12" Margin="0,0,6,0" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" />
            <ComboBox Width="180" FontSize="12" Margin="0,0,6,0" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding CircleOptions}" Text="{Binding SelectedCircle, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Width="180" FontSize="12" Margin="0,0,6,0" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding TagOptions}" Text="{Binding SelectedTag, UpdateSourceTrigger=PropertyChanged}" />
            <Button Style="{StaticResource DarkButton}" Content="クリア" Padding="10,4" FontSize="12" Command="{Binding ClearFiltersCommand}" />
          </StackPanel>
        </Border>
        <ListBox Grid.Row="2" Background="#00FFFFFF" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.CacheLengthUnit="Page" VirtualizingPanel.CacheLength="1,1" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel" SelectionMode="Single" ItemsSource="{Binding GamesView}" SelectedItem="{Binding SelectedGame}" PreviewMouseWheel="OnListBox_PreviewMouseWheel">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <vwp:VirtualizingWrapPanel xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemContainerStyle>
            <Style TargetType="{x:Type ListBoxItem}">
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <ContentPresenter />
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ItemsControl.ItemContainerStyle>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Width="280" Margin="6" Background="{StaticResource BgCard}" CornerRadius="6" Cursor="Hand" ToolTipService.InitialShowDelay="2000" MouseLeftButtonDown="OnGameCard_Click">
                <FrameworkElement.ToolTip>
                  <ToolTip MaxWidth="520" Placement="Right" Background="#1e1e2e" BorderBrush="#45455a" BorderThickness="1" Padding="0">
                    <StackPanel>
                      <Image MaxWidth="500" MaxHeight="400" Stretch="Uniform" Margin="4" Source="{Binding ThumbnailPath, Converter={StaticResource PathToImage}, ConverterParameter=500}" />
                      <TextBlock Foreground="#cdd6f4" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="8,4,8,2" Text="{Binding Title}" />
                      <TextBlock Foreground="#9399b2" FontSize="11" Margin="8,0,8,6" Text="{Binding CircleName}" />
                    </StackPanel>
                  </ToolTip>
                </FrameworkElement.ToolTip>
                <FrameworkElement.Style>
                  <Style TargetType="{x:Type Border}">
                    <Style.Triggers>
                      <Trigger Property="UIElement.IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgCardHover}" />
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </FrameworkElement.Style>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="190" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Border Grid.Row="0" CornerRadius="6,6,0,0" ClipToBounds="True">
                    <Grid>
                      <Border Background="#252540">
                        <TextBlock Foreground="{StaticResource FgSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Text="{Binding ProductId}" />
                      </Border>
                      <Image Stretch="UniformToFill" Source="{Binding ThumbnailPath, Converter={StaticResource PathToImage}}" />
                    </Grid>
                  </Border>
                  <TextBlock Grid.Row="1" Foreground="{StaticResource FgPrimary}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxHeight="40" Margin="8,8,8,2" Text="{Binding Title}" />
                  <TextBlock Grid.Row="2" Foreground="{StaticResource FgSecondary}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="8,0,8,4" Cursor="Hand" Text="{Binding CircleName}" MouseLeftButtonDown="OnCircleName_Click">
                    <FrameworkElement.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="サークル名で絞り込み" Click="OnCircleNameFilter_Click" />
                        <MenuItem Header="内蔵ブラウザで検索" Click="OnSearchCircleInBrowser_Click" />
                      </ContextMenu>
                    </FrameworkElement.ContextMenu>
                    <FrameworkElement.Style>
                      <Style TargetType="{x:Type TextBlock}">
                        <Style.Triggers>
                          <Trigger Property="UIElement.IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#89b4fa" />
                            <Setter Property="TextDecorations" Value="Underline" />
                          </Trigger>
                        </Style.Triggers>
                      </Style>
                    </FrameworkElement.Style>
                  </TextBlock>
                  <TextBlock Grid.Row="3" Foreground="{StaticResource FgSecondary}" FontSize="10" Margin="8,0,8,8" Text="{Binding LastPlayedAt, Converter={StaticResource DateTimeToString}}" />
                </Grid>
                <FrameworkElement.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="起動" FontWeight="Bold" Click="OnLaunchGame_Click" />
                    <MenuItem Header="フォルダを開く" Click="OnOpenFolder_Click" />
                    <MenuItem Header="作品ページを開く" Click="OnOpenProductPage_Click" />
                    <MenuItem Header="内蔵ブラウザで開く" Click="OnOpenInBuiltInBrowser_Click" />
                    <Separator />
                    <MenuItem Header="メタデータを再取得" Click="OnRefetchMetadata_Click" />
                    <Separator />
                    <MenuItem Header="プロパティ" Click="OnProperty_Click" />
                    <Separator />
                    <MenuItem Header="削除" Click="OnDeleteGame_Click" />
                  </ContextMenu>
                </FrameworkElement.ContextMenu>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ListBox>
      </Grid>
      <Grid Name="BrowserPanel" Visibility="{Binding IsBrowserTabActive, Converter={StaticResource BoolToVisibility}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}" Padding="8,6">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="←" Style="{StaticResource DarkButton}" Padding="8,4" Margin="0,0,4,0" Click="OnBrowserBack_Click" />
            <Button Grid.Column="1" Content="→" Style="{StaticResource DarkButton}" Padding="8,4" Margin="0,0,4,0" Click="OnBrowserForward_Click" />
            <TextBox Name="UrlBar" Grid.Column="2" Style="{StaticResource DarkTextBox}" Margin="0,0,4,0" Text="{Binding BrowserUrl, UpdateSourceTrigger=PropertyChanged}" KeyDown="OnUrlBar_KeyDown" />
            <Button Grid.Column="3" Content="移動" Style="{StaticResource AccentButton}" Padding="12,4" Margin="0,0,4,0" Click="OnNavigate_Click" />
            <Button Grid.Column="4" Content="🏠" Style="{StaticResource DarkButton}" Padding="8,4" Click="OnBrowserHome_Click" />
          </Grid>
        </Border>
        <wv2:WebView2 x:Name="WebView" Grid.Row="1">
          <!--Unknown connection ID: 26-->
        </wv2:WebView2>
      </Grid>
    </Grid>
    <Border Grid.Row="2" Background="{StaticResource BgSecondary}" Padding="12,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Foreground="{StaticResource FgSecondary}" FontSize="12" VerticalAlignment="Center" Text="{Binding StatusText}" />
        <Grid Column="1" />
        <TextBlock Grid.Column="2" Foreground="{StaticResource AccentBlue}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding LoadingMessage}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
        <ProgressBar Grid.Column="3" Width="160" Height="8" Minimum="0" Background="#383850" Foreground="#89b4fa" VerticalAlignment="Center" Maximum="{Binding FetchTotal}" Value="{Binding FetchDone}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
      </Grid>
    </Border>
  </Grid>
</Window>